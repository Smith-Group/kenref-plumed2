/* end confdefs.h.  */

/* random program calling all the functions needed to manage a subprocess */
#include <cstdio>
#include <unistd.h>
#include <csignal>

int
main ()
{
// notice that [] is required to cheat autoconf
  int cp[2];
  FILE* fp;
  char* arr[3];
  arr[0]=NULL;
  arr[1]=NULL;
  arr[2]=NULL;
  arr[3]=NULL;
  if(pipe(cp)>=0)
  if(fork()>=0)
  if(close(1)>=0)
  if(dup(cp[1])>=0) {
    fp=fdopen(cp[0],"w");
    execv(arr[0],arr);
  }
  auto p=fork();
  kill(p,SIGINT);
  kill(p,SIGCONT);
  kill(p,SIGSTOP);
  return 0;
}


