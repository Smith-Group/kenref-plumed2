if test ${enable_static_archive+y}
then :
  enableval=$enable_static_archive; case "${enableval}" in
             (yes) static_archive=true ;;
             (no)  static_archive=false ;;
             (*)   as_fn_error $? "wrong argument to --enable-static-archive" "$LINENO" 5 ;;
  esac
else case e in #(
  e) case "yes" in
             (yes) static_archive=true ;;
             (no)  static_archive=false ;;
  esac
 ;;
esac
fi



