      have_kenref=no

elif test $pkg_failed = untried; then
     	{ printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: no" >&5
printf "%s\n" "no" >&6; }

      # FAILURE 2: Neither option worked.
      { printf "%s\n" "$as_me:${as_lineno-$LINENO}:     FAILURE: KEnRef integration not possible. Neither pkg-config file found." >&5
printf "%s\n" "$as_me:     FAILURE: KEnRef integration not possible. Neither pkg-config file found." >&6;}
      HAVE_KENREF=no

      have_kenref=no

else
	KENREF_FALLBACK_CFLAGS=$pkg_cv_KENREF_FALLBACK_CFLAGS
	KENREF_FALLBACK_LIBS=$pkg_cv_KENREF_FALLBACK_LIBS
        { printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: yes" >&5
printf "%s\n" "yes" >&6; }


      # SUCCESS 2: Found the fallback. Set final variables.
      { printf "%s\n" "$as_me:${as_lineno-$LINENO}:     SUCCESS: KEnRef linked with self-contained library." >&5
printf "%s\n" "$as_me:     SUCCESS: KEnRef linked with self-contained library." >&6;}

      KENREF_LIBS="$KENREF_FALLBACK_LIBS"

      KENREF_INCLUDE="$KENREF_FALLBACK_CFLAGS"

      HAVE_KENREF=yes

      # Next line is new
      LIBS="$KENREF_FALLBACK_LIBS $LIBS"
      have_kenref=yes

fi

fi

  # Final status output
  { printf "%s\n" "$as_me:${as_lineno-$LINENO}: KEnRef Final Status: $HAVE_KENREF" >&5
printf "%s\n" "$as_me: KEnRef Final Status: $HAVE_KENREF" >&6;}

  if test "$HAVE_KENREF" != yes ; then
    as_fn_error $? "KEnRef requested but kenref_core >= $KENREF_MIN_VERSION could not be located even after
  fetch+build. See the build log above, or pass --with-kenref-src=DIR / set KENREF_GIT_URL." "$LINENO" 5
  fi

  # Resolve the module's COMPILE includes ONCE, here, while PKG_CONFIG_PATH is set, and bake them into
  # Makefile.conf (KENREF_PLUMED_INCLUDE -> src/kenref/Makefile's KENREF_PLUMED_CPPFLAGS). This mirrors how the
  # LINK flags already flow (configure -> LIBS -> DYNAMIC_LIBS): the module never calls pkg-config at make
  # time, so a later `sudo make install` (which re-parses src/kenref/Makefile as root with PKG_CONFIG_PATH
  # stripped) still gets the flags configure captured. kenref_plumed.pc exposes -I core -I plumedinterface
  # -I src (+ eigen3) -- the Option-A source paths kenref_core.pc lacks.
  KENREF_PLUMED_INCLUDE=`pkg-config --cflags kenref_plumed 2>/dev/null`

  if test -z "$KENREF_PLUMED_INCLUDE" ; then
    as_fn_error $? "KEnRef: kenref_core was found but kenref_plumed.pc was not (needed for the module's
  plumedinterface include paths). Ensure the kenref install was built with -DKENREF_EXPORT_PLUMEDINTERFACE=ON
  and that its prefix is on PKG_CONFIG_PATH." "$LINENO" 5
  fi
  { printf "%s\n" "$as_me:${as_lineno-$LINENO}: KEnRef: module compile includes baked into Makefile.conf: $KENREF_PLUMED_INCLUDE" >&5
printf "%s\n" "$as_me: KEnRef: module compile includes baked into Makefile.conf: $KENREF_PLUMED_INCLUDE" >&6;}
else
  # Neither switch: do not search, do not depend, do not build the module.
  { printf "%s\n" "$as_me:${as_lineno-$LINENO}: KEnRef: disabled (neither --enable-kenref nor --enable-modules=+kenref) -> module not built." >&5
printf "%s\n" "$as_me: KEnRef: disabled (neither --enable-kenref nor --enable-modules=+kenref) -> module not built." >&6;}
  HAVE_KENREF=no

  have_kenref=no
fi

